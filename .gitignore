# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
uploads/*
!uploads/README.md
datasets/raw
datasets/rectified
datasets/masks
datasets/cardref/*
!datasets/cardref/README.md
datasets/eval/*
!datasets/eval/README.md
!datasets/eval/labels.example.json

# tesseract.js language models (downloaded on first headless OCR run)
*.traineddata

# Recognizer index under public/cardref IS committed (~2.6MB): Vercel serves
# static files straight from the repo, so ignoring it silently downgrades
# deployed recognition to the heuristic. Regenerate via
# scripts/build-embedding-index.ts when the catalog grows.

# Calibration photos (private)
datasets/calibration/*
!datasets/calibration/README.md

# Synthetic segmentation training data (regenerate via scripts/gen-seg-data.ts)
datasets/seg/
training/out/
